# Environment file untuk Development
# Copy to .env (untuk development lokal)

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=development-secret-key

# Database (jika diperlukan)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=medical_expert_dev
# DB_USER=dev_user
# DB_PASSWORD=dev_password

# Application
APP_NAME=medical-expert-system
APP_VERSION=1.0.0
LOG_LEVEL=DEBUG

# API Configuration
API_PORT=5000
API_WORKERS=1
API_TIMEOUT=30

# Testing
TESTING=false
